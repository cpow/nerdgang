<%= turbo_stream.replace "add-to-newsletter-#{@article.id}" do %>
  <%= render "admin/articles/add_to_newsletter_button", article: @article %>
<% end %>

<%= turbo_stream.replace "article-newsletters-#{@article.id}" do %>
  <%= render "admin/articles/newsletters_section", article: @article %>
<% end %>

<%= turbo_stream.prepend "flash" do %>
  <div class="mb-4 p-4 rounded bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 border border-green-200 dark:border-green-800" data-controller="flash" data-flash-timeout-value="5000">
    <div class="flex items-center justify-between">
      <span><%= flash[:notice] %></span>
      <button type="button" data-action="click->flash#dismiss" class="text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
  </div>
<% end %>
