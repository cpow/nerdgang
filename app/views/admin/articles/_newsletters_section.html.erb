<div id="article-newsletters-<%= article.id %>" class="mt-6">
  <% newsletters = article.newsletters.kept %>
  <% if newsletters.any? %>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded p-6">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600 dark:text-green-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        In Newsletters
      </h3>
      <div class="flex flex-wrap gap-2">
        <% newsletters.each do |newsletter| %>
          <%= link_to admin_newsletter_path(newsletter),
              class: "inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors" do %>
            <%= newsletter.title %>
            <% if newsletter.published? %>
              <span class="text-xs opacity-75">(Published)</span>
            <% else %>
              <span class="text-xs opacity-75">(Draft)</span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
