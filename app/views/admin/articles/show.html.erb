<% content_for(:title) { "#{@article.title} - News Admin" } %>

<div class="mb-6">
  <%= link_to "&larr; Back to Articles".html_safe, admin_articles_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" %>
</div>

<div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded p-6">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
    <a href="<%= @article.url %>" target="_blank" class="hover:text-blue-600 dark:hover:text-blue-400">
      <%= @article.title %>
    </a>
  </h2>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Source</div>
      <div class="font-medium text-gray-900 dark:text-white">
        <% if @article.reddit? %>
          r/<%= @article.source_name %>
        <% else %>
          Hacker News
        <% end %>
      </div>
    </div>
    <div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Score</div>
      <div class="font-medium text-gray-900 dark:text-white"><%= @article.score %></div>
    </div>
    <div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Comments</div>
      <div class="font-medium">
        <a href="<%= @article.discussion_url %>" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">
          <%= @article.comments_count %>
        </a>
      </div>
    </div>
    <div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Author</div>
      <div class="font-medium text-gray-900 dark:text-white"><%= @article.author || "Unknown" %></div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 text-sm text-gray-500 dark:text-gray-400 border-t border-gray-200 dark:border-gray-700 pt-4">
    <div>
      <span class="font-medium">Domain:</span> <%= @article.domain %>
    </div>
    <div>
      <span class="font-medium">Published:</span> <%= @article.published_at&.strftime("%B %d, %Y at %H:%M") %>
    </div>
    <div>
      <span class="font-medium">Scraped:</span> <%= @article.scraped_at.strftime("%B %d, %Y at %H:%M") %>
    </div>
    <div>
      <span class="font-medium">External ID:</span> <%= @article.external_id %>
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-4">
    <a href="<%= @article.url %>" target="_blank" class="bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-4 py-2 rounded text-sm hover:bg-gray-800 dark:hover:bg-gray-200">
      Visit Article
    </a>
    <a href="<%= @article.discussion_url %>" target="_blank" class="border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 px-4 py-2 rounded text-sm hover:bg-gray-50 dark:hover:bg-gray-700">
      View Discussion
    </a>
    <%= render "admin/articles/add_to_newsletter_button", article: @article %>
    <%= button_to "Delete", admin_article_path(@article),
        method: :delete,
        class: "border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 px-4 py-2 rounded text-sm hover:bg-red-50 dark:hover:bg-red-900/30",
        data: { turbo_confirm: "Delete this article?" } %>
  </div>
</div>

<!-- Newsletters Section -->
<%= render "admin/articles/newsletters_section", article: @article %>
