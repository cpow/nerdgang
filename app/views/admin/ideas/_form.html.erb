<%= form_with model: [:admin, idea], class: "space-y-6" do |f| %>
  <% if idea.errors.any? %>
    <div class="p-4 bg-red-100 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded">
      <h3 class="text-sm font-medium text-red-800 dark:text-red-300"><%= pluralize(idea.errors.count, "error") %> prohibited this idea from being saved:</h3>
      <ul class="mt-2 text-sm text-red-700 dark:text-red-400 list-disc list-inside">
        <% idea.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Left Column: Core Info -->
    <div class="space-y-6">
      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_field :title, placeholder: "I Built a Raspberry Pi That...", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :angle, "Angle / Unique Twist", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :angle, rows: 3, placeholder: "What makes this video unique? Why would someone click?", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :hook, "Opening Hook (first 10 seconds)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :hook, rows: 2, placeholder: "What do you say/show to stop the scroll?", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :thumbnail_concept, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_field :thumbnail_concept, placeholder: "Shocked face, holding chip, text: '$3 LINUX??'", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :key_points, "Key Points / Outline", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :key_points, rows: 4, placeholder: "- Point 1\n- Point 2\n- Point 3", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono text-sm" %>
      </div>
    </div>

    <!-- Right Column: Metadata -->
    <div class="space-y-6">
      <div>
        <%= f.label :hardware_components, "Hardware Components", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_field :hardware_components, placeholder: "Raspberry Pi 5, ESP32, breadboard, sensors...", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :difficulty, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.select :difficulty, [["Beginner", "beginner"], ["Intermediate", "intermediate"], ["Advanced", "advanced"]], { include_blank: "Select..." }, class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= f.label :score, "Score (1-100)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.number_field :score, min: 1, max: 100, placeholder: "75", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
      </div>

      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.select :status, Idea::STATUSES.map { |s| [s.capitalize, s] }, {}, class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :creator_channel_id, "Inspired By Channel", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.collection_select :creator_channel_id, CreatorChannel.order(:name), :id, :name, { include_blank: "None (Original idea)" }, class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :notes, "Additional Notes", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :notes, rows: 3, placeholder: "Research links, references, etc.", class: "w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
    <%= f.submit class: "px-4 py-2 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-200 cursor-pointer" %>
    <%= link_to "Cancel", admin_ideas_path, class: "px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-700" %>
  </div>
<% end %>
