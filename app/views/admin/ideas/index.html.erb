<% content_for(:title) { "Video Ideas - News Admin" } %>
<% content_for(:page_title) { "Video Ideas" } %>
<% content_for(:page_actions) do %>
  <%= link_to new_admin_idea_path, class: "inline-flex items-center gap-2 px-3 py-1.5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-200" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Add Idea
  <% end %>
<% end %>

<div class="space-y-6">

  <!-- Ideas Table -->
  <div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 overflow-hidden">
    <% if @ideas.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Title</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Hardware</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Difficulty</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Status</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Score</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @ideas.each do |idea| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30">
                <td class="px-5 py-4">
                  <div class="font-medium text-gray-900 dark:text-gray-100"><%= truncate(idea.title, length: 50) %></div>
                  <% if idea.angle.present? %>
                    <div class="mt-1 text-xs text-gray-500 dark:text-gray-400 line-clamp-1"><%= truncate(idea.angle, length: 80) %></div>
                  <% end %>
                  <% if idea.notes&.include?("AI-generated") %>
                    <span class="inline-flex items-center gap-1 mt-1 text-xs text-purple-600 dark:text-purple-400">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                      </svg>
                      AI
                    </span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-xs text-gray-500 dark:text-gray-400 max-w-32">
                  <% if idea.hardware_components.present? %>
                    <span class="line-clamp-2"><%= idea.hardware_components %></span>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-5 py-4">
                  <% if idea.difficulty.present? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= difficulty_badge_class(idea.difficulty) %>">
                      <%= idea.difficulty.capitalize %>
                    </span>
                  <% else %>
                    <span class="text-gray-400 dark:text-gray-500">-</span>
                  <% end %>
                </td>
                <td class="px-5 py-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium <%= status_badge_class(idea.status) %>">
                    <%= idea.status.capitalize %>
                  </span>
                </td>
                <td class="px-5 py-4">
                  <% if idea.score.present? %>
                    <div class="flex items-center gap-2">
                      <div class="w-12 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full <%= idea.score >= 70 ? 'bg-green-500' : idea.score >= 40 ? 'bg-yellow-500' : 'bg-gray-400' %>" style="width: <%= idea.score %>%"></div>
                      </div>
                      <span class="text-sm text-gray-700 dark:text-gray-300 font-medium"><%= idea.score %></span>
                    </div>
                  <% else %>
                    <span class="text-gray-400 dark:text-gray-500">-</span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-right">
                  <%= link_to edit_admin_idea_path(idea), class: "text-sm text-blue-600 dark:text-blue-400 hover:underline font-medium" do %>
                    Edit
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        No ideas yet. Add an idea manually or use the Creator Dashboard to generate suggestions.
      </div>
    <% end %>
  </div>
</div>
