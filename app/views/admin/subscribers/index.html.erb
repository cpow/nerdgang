<% content_for(:title) { "Subscribers - News Admin" } %>
<% content_for(:page_title) { "Subscribers" } %>
<% content_for(:page_actions) do %>
  <span class="text-sm text-gray-500 dark:text-gray-400"><%= @subscribers.count %> total</span>
<% end %>

<div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
    <thead class="bg-gray-50 dark:bg-gray-900">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Subscribed</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
      <% @subscribers.each do |subscriber| %>
        <tr>
          <td class="px-6 py-4 text-sm">
            <%= link_to subscriber.email, admin_subscriber_path(subscriber), class: "text-blue-600 dark:text-blue-400 hover:underline" %>
          </td>
          <td class="px-6 py-4 text-sm">
            <% if subscriber.subscribed? %>
              <span class="text-green-600 dark:text-green-400">Active</span>
            <% else %>
              <span class="text-red-600 dark:text-red-400">Unsubscribed</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400"><%= subscriber.created_at.strftime("%B %d, %Y at %H:%M") %></td>
        </tr>
      <% end %>
      <% if @subscribers.empty? %>
        <tr>
          <td colspan="3" class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 text-center">No subscribers yet.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
