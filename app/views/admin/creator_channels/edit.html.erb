<% content_for(:title) { "Edit #{@creator_channel.name} - News Admin" } %>
<% content_for(:page_title) do %>
  <div class="flex items-center gap-3">
    <%= link_to admin_creator_channels_path, class: "text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <span>Edit <%= @creator_channel.name %></span>
  </div>
<% end %>

<div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 p-6">
  <%= render "form", creator_channel: @creator_channel %>
</div>
