<div class="w-full space-y-4">
  <div class="flex justify-between">
    <h1 class="text-2xl font-semibold">Creator Channels</h1>
    <%= link_to "Add channel", new_admin_creator_channel_path, class: "px-3 py-2 bg-blue-600 text-white rounded" %>
  </div>

  <table class="w-full text-sm bg-white border rounded">
    <thead><tr class="text-left"><th>Name</th><th>Handle</th><th>YouTube ID</th><th>Active</th><th></th></tr></thead>
    <tbody>
      <% @creator_channels.each do |channel| %>
        <tr class="border-t">
          <td><%= channel.name %></td>
          <td><%= channel.handle %></td>
          <td><%= channel.youtube_channel_id %></td>
          <td><%= channel.active? ? "Yes" : "No" %></td>
          <td><%= link_to "Edit", edit_admin_creator_channel_path(channel), class: "text-blue-600" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
