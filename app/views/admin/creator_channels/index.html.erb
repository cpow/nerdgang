<% content_for(:title) { "Creator Channels - News Admin" } %>
<% content_for(:page_title) { "Creator Channels" } %>
<% content_for(:page_actions) do %>
  <%= link_to new_admin_creator_channel_path, class: "inline-flex items-center gap-2 px-3 py-1.5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-200" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Add Channel
  <% end %>
<% end %>

<div class="space-y-6">

  <!-- Channels Table -->
  <div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 overflow-hidden">
    <% if @creator_channels.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Name</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Handle</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">YouTube ID</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Videos</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50">Status</th>
              <th class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @creator_channels.each do |channel| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30">
                <td class="px-5 py-4">
                  <div class="font-medium text-gray-900 dark:text-gray-100"><%= channel.name %></div>
                  <% if channel.niche_tags_array.any? %>
                    <div class="mt-1 flex flex-wrap gap-1">
                      <% channel.niche_tags_array.first(3).each do |tag| %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400"><%= tag %></span>
                      <% end %>
                      <% if channel.niche_tags_array.size > 3 %>
                        <span class="text-xs text-gray-400 dark:text-gray-500">+<%= channel.niche_tags_array.size - 3 %></span>
                      <% end %>
                    </div>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-gray-700 dark:text-gray-300 font-mono text-xs"><%= channel.handle %></td>
                <td class="px-5 py-4 text-gray-500 dark:text-gray-400 font-mono text-xs">
                  <% if channel.youtube_channel_id.present? %>
                    <%= truncate(channel.youtube_channel_id, length: 20) %>
                  <% else %>
                    <span class="text-red-500 dark:text-red-400">Not set</span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-gray-700 dark:text-gray-300"><%= channel.creator_videos.count %></td>
                <td class="px-5 py-4">
                  <% if channel.active? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300">Active</span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">Inactive</span>
                  <% end %>
                </td>
                <td class="px-5 py-4 text-right">
                  <%= link_to edit_admin_creator_channel_path(channel), class: "text-sm text-blue-600 dark:text-blue-400 hover:underline font-medium" do %>
                    Edit
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        No channels yet. Click "Add Channel" to start tracking a YouTube channel.
      </div>
    <% end %>
  </div>
</div>
