<% content_for(:title) { "Dashboard - News Admin" } %>

<div class="mb-6">
  <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Dashboard</h2>
</div>

<!-- Subscriber Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
  <div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Total Subscribers</div>
    <div class="text-3xl font-semibold text-gray-900 dark:text-white"><%= @stats[:total_subscribers] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">New Today</div>
    <div class="text-3xl font-semibold text-gray-900 dark:text-white"><%= @stats[:subscribers_today] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">This Week</div>
    <div class="text-3xl font-semibold text-gray-900 dark:text-white"><%= @stats[:subscribers_this_week] %></div>
  </div>
</div>

<!-- Subscriber Growth Chart -->
<div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700 mb-8">
  <div class="flex justify-between items-center mb-4">
    <h3 class="text-base font-medium text-gray-900 dark:text-white">Subscriber Growth</h3>
    <span class="text-xs text-gray-500 dark:text-gray-400">Last 30 days</span>
  </div>

  <% max_count = @subscriber_daily_signups.map { |d| d[:count] }.max || 1 %>
  <div class="relative" data-controller="bar-chart" style="height: 160px;">
    <div data-bar-chart-target="tooltip"
         class="hidden absolute text-xs bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-2 py-1 rounded pointer-events-none -translate-x-1/2 -translate-y-full whitespace-nowrap"
         style="z-index: 10;">
    </div>
    <div class="flex items-end gap-px h-full">
      <% @subscriber_daily_signups.each do |day| %>
        <% height_pct = max_count > 0 ? (day[:count].to_f / max_count * 100).round : 0 %>
        <div class="flex-1 flex flex-col justify-end h-full cursor-pointer group"
             data-action="mouseenter->bar-chart#show mouseleave->bar-chart#hide"
             data-label="<%= day[:date].strftime("%b %d") %>"
             data-value="<%= pluralize(day[:count], 'signup') %>">
          <div class="w-full rounded-t bg-blue-500 dark:bg-blue-400 group-hover:bg-blue-600 dark:group-hover:bg-blue-300 transition-colors"
               style="height: <%= height_pct > 0 ? [height_pct, 4].max : 0 %>%; min-height: <%= day[:count] > 0 ? '3px' : '0' %>;">
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <div class="flex justify-between mt-2 text-xs text-gray-400 dark:text-gray-500">
    <span><%= 29.days.ago.to_date.strftime("%b %d") %></span>
    <span>Today</span>
  </div>
</div>

<!-- Article Stats -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Total Articles</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:total_articles] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Today</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:articles_today] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">This Week</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:articles_this_week] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Last Scrape</div>
    <div class="text-sm font-medium text-gray-900 dark:text-white">
      <%= @stats[:last_scrape]&.strftime("%b %d, %H:%M") || "Never" %>
    </div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">By Source</div>
    <div class="text-xs text-gray-700 dark:text-gray-300 mt-1 space-y-0.5">
      <div>Reddit: <%= @stats[:by_source]["reddit"] || 0 %></div>
      <div>HN: <%= @stats[:by_source]["hackernews"] || 0 %></div>
      <div>Lobste.rs: <%= @stats[:by_source]["lobsters"] || 0 %></div>
      <div>Dev.to: <%= @stats[:by_source]["devto"] || 0 %></div>
      <div>IH: <%= @stats[:by_source]["indiehackers"] || 0 %></div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <div>
    <h3 class="text-base font-medium text-gray-900 dark:text-white mb-4">Recent Articles</h3>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded overflow-hidden">
      <% if @recent_articles.any? %>
        <ul class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_articles.each do |article| %>
            <li class="p-4">
              <%= link_to admin_article_path(article), class: "text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400" do %>
                <%= truncate(article.title, length: 70) %>
              <% end %>
              <div class="mt-1 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                <span><%= source_label(article) %></span>
                <span><%= article.score %> pts</span>
                <span><%= time_ago_in_words(article.published_at) %> ago</span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-4 text-sm text-gray-500 dark:text-gray-400">No articles yet. Click "Refresh All" to scrape sources.</div>
      <% end %>
    </div>
  </div>

  <div>
    <h3 class="text-base font-medium text-gray-900 dark:text-white mb-4">Top Articles This Week</h3>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded overflow-hidden">
      <% if @top_articles.any? %>
        <ul class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @top_articles.each do |article| %>
            <li class="p-4">
              <%= link_to admin_article_path(article), class: "text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400" do %>
                <%= truncate(article.title, length: 70) %>
              <% end %>
              <div class="mt-1 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                <span><%= source_label(article) %></span>
                <span><%= article.score %> pts</span>
                <span><%= article.comments_count %> comments</span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-4 text-sm text-gray-500 dark:text-gray-400">No articles this week.</div>
      <% end %>
    </div>
  </div>
</div>
