<% content_for(:title) { "Dashboard - News Admin" } %>

<div class="mb-6">
  <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Dashboard</h2>
</div>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Total Articles</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:total_articles] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Today</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:articles_today] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">This Week</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:articles_this_week] %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Reddit</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:by_source]["reddit"] || 0 %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Hacker News</div>
    <div class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @stats[:by_source]["hackernews"] || 0 %></div>
  </div>
  <div class="bg-white dark:bg-gray-800 p-4 rounded border border-gray-200 dark:border-gray-700">
    <div class="text-sm text-gray-500 dark:text-gray-400">Last Scrape</div>
    <div class="text-sm font-medium text-gray-900 dark:text-white">
      <% last_scrape = [@stats[:last_reddit_scrape], @stats[:last_hn_scrape]].compact.max %>
      <%= last_scrape&.strftime("%b %d, %H:%M") || "Never" %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <div>
    <h3 class="text-base font-medium text-gray-900 dark:text-white mb-4">Recent Articles</h3>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded overflow-hidden">
      <% if @recent_articles.any? %>
        <ul class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_articles.each do |article| %>
            <li class="p-4">
              <%= link_to admin_article_path(article), class: "text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400" do %>
                <%= truncate(article.title, length: 70) %>
              <% end %>
              <div class="mt-1 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                <span><%= article.source == "reddit" ? "r/#{article.source_name}" : "HN" %></span>
                <span><%= article.score %> pts</span>
                <span><%= time_ago_in_words(article.published_at) %> ago</span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-4 text-sm text-gray-500 dark:text-gray-400">No articles yet. Click "Refresh All" to scrape sources.</div>
      <% end %>
    </div>
  </div>

  <div>
    <h3 class="text-base font-medium text-gray-900 dark:text-white mb-4">Top Articles This Week</h3>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded overflow-hidden">
      <% if @top_articles.any? %>
        <ul class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @top_articles.each do |article| %>
            <li class="p-4">
              <%= link_to admin_article_path(article), class: "text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400" do %>
                <%= truncate(article.title, length: 70) %>
              <% end %>
              <div class="mt-1 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                <span><%= article.source == "reddit" ? "r/#{article.source_name}" : "HN" %></span>
                <span><%= article.score %> pts</span>
                <span><%= article.comments_count %> comments</span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-4 text-sm text-gray-500 dark:text-gray-400">No articles this week.</div>
      <% end %>
    </div>
  </div>
</div>
