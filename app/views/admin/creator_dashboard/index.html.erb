<% content_for(:title) { "Creator Intelligence - News Admin" } %>
<% content_for(:page_title) { "Creator Intelligence" } %>
<% content_for(:page_actions) do %>
  <%= button_to sync_admin_creator_dashboard_index_path,
      method: :post,
      class: "inline-flex items-center gap-2 px-3 py-1.5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-200" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
    </svg>
    Sync Now
  <% end %>
  <%= button_to generate_suggestions_admin_creator_dashboard_index_path,
      method: :post,
      class: "inline-flex items-center gap-2 px-3 py-1.5 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 rounded text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-700" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
    </svg>
    Generate Suggestions
  <% end %>
<% end %>

<div class="space-y-6">

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700">
      <div class="text-sm text-gray-500 dark:text-gray-400">Channels Tracked</div>
      <div class="text-3xl font-semibold text-gray-900 dark:text-white"><%= @creator_channels.count %></div>
    </div>
    <div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700">
      <div class="text-sm text-gray-500 dark:text-gray-400">Videos Tracked</div>
      <div class="text-3xl font-semibold text-gray-900 dark:text-white"><%= @videos.count %></div>
    </div>
    <div class="bg-white dark:bg-gray-800 p-5 rounded border border-gray-200 dark:border-gray-700">
      <div class="text-sm text-gray-500 dark:text-gray-400">Ideas in Backlog</div>
      <div class="text-3xl font-semibold text-gray-900 dark:text-white"><%= Idea.backlog.count %></div>
    </div>
  </div>

  <!-- Recent Videos by Channel (sorted by views/hour) -->
  <div class="space-y-4">
    <h2 class="text-base font-medium text-gray-900 dark:text-white">Recent Videos by Channel</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400">Top 5 videos from the last 14 days, ranked by views per hour</p>

    <% @recent_videos_by_channel.each do |channel, videos| %>
      <div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="px-5 py-3 bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700">
          <span class="text-sm font-medium text-gray-900 dark:text-white"><%= channel.name %></span>
          <span class="text-xs text-gray-500 dark:text-gray-400 ml-2"><%= channel.handle %></span>
        </div>
        <% if videos.any? %>
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            <% videos.each do |video| %>
              <div class="px-5 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/30 flex items-center justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <a href="https://youtube.com/watch?v=<%= video.youtube_video_id %>" target="_blank" class="text-sm text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 line-clamp-1">
                    <%= video.title %>
                  </a>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                    <%= time_ago_in_words(video.published_at) %> ago
                  </div>
                </div>
                <div class="text-right flex-shrink-0">
                  <div class="text-sm font-medium text-gray-900 dark:text-white">
                    <%= number_with_delimiter((video.views_per_hour || 0).round) %>/hr
                  </div>
                  <div class="text-xs text-gray-500 dark:text-gray-400">
                    <%= number_with_delimiter(video.view_count) %> views
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-5 py-4 text-sm text-gray-500 dark:text-gray-400">
            No videos in the last 14 days
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @recent_videos_by_channel.empty? %>
      <div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 px-5 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        No channels tracked yet. Add channels to start tracking videos.
      </div>
    <% end %>
  </div>

  <!-- Idea Board -->
  <div class="bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <h2 class="text-base font-medium text-gray-900 dark:text-white">Idea Board</h2>
      <%= link_to admin_ideas_path, class: "text-sm text-blue-600 dark:text-blue-400 hover:underline" do %>
        View all
      <% end %>
    </div>
    <% if @ideas.any? %>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @ideas.each do |idea| %>
          <div class="px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-700/30">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <%= link_to edit_admin_idea_path(idea), class: "text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400" do %>
                  <%= idea.title %>
                <% end %>
                <% if idea.angle.present? %>
                  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 line-clamp-2"><%= idea.angle %></p>
                <% end %>
              </div>
              <div class="flex items-center gap-2">
                <% if idea.score.present? %>
                  <span class="text-xs font-medium text-gray-500 dark:text-gray-400"><%= idea.score %></span>
                <% end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium <%= status_badge_class(idea.status) %>">
                  <%= idea.status.capitalize %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        No ideas yet. Click "Generate Suggestions" to create AI-powered video ideas.
      </div>
    <% end %>
  </div>
</div>
