<div class="w-full space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold">Creator Intelligence Dashboard</h1>
    <%= button_to "Sync now", sync_admin_creator_dashboard_index_path, method: :post, class: "px-4 py-2 bg-blue-600 text-white rounded" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white rounded border p-4">
      <p class="text-sm text-gray-500">Channels tracked</p>
      <p class="text-2xl font-bold"><%= @creator_channels.count %></p>
    </div>
    <div class="bg-white rounded border p-4">
      <p class="text-sm text-gray-500">Videos tracked</p>
      <p class="text-2xl font-bold"><%= @videos.count %></p>
    </div>
    <div class="bg-white rounded border p-4">
      <p class="text-sm text-gray-500">Ideas in backlog</p>
      <p class="text-2xl font-bold"><%= Idea.backlog.count %></p>
    </div>
  </div>

  <div class="bg-white rounded border p-4">
    <h2 class="font-semibold mb-3">Top competitor videos</h2>
    <table class="w-full text-sm">
      <thead><tr class="text-left"><th>Channel</th><th>Title</th><th>Views</th><th>Published</th></tr></thead>
      <tbody>
      <% @top_competitor_videos.each do |video| %>
        <tr class="border-t">
          <td><%= video.creator_channel.name %></td>
          <td><%= video.title %></td>
          <td><%= number_with_delimiter(video.view_count) %></td>
          <td><%= video.published_at&.to_date %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>

  <div class="bg-white rounded border p-4">
    <h2 class="font-semibold mb-3">Idea board</h2>
    <div class="space-y-2">
      <% @ideas.each do |idea| %>
        <div class="p-3 border rounded">
          <div class="flex items-center justify-between">
            <p class="font-medium"><%= idea.title %></p>
            <span class="text-xs px-2 py-1 bg-gray-100 rounded"><%= idea.status %></span>
          </div>
          <p class="text-sm text-gray-600"><%= idea.angle %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
