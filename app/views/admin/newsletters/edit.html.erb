<% content_for(:title) { "Edit #{@newsletter.title} - News Admin" } %>

<div class="mb-6">
  <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Edit Newsletter</h2>
  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= @newsletter.title %></p>
</div>

<div class="bg-white dark:bg-gray-800 p-6 rounded border border-gray-200 dark:border-gray-700">
  <%= render "form", newsletter: @newsletter %>
</div>
