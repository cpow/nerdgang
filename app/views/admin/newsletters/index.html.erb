<% content_for(:title) { "Newsletters - News Admin" } %>

<div class="mb-6">
  <div class="flex justify-between items-center">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Newsletters</h2>
    <%= link_to "New Newsletter", new_admin_newsletter_path,
        class: "bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-4 py-2 rounded text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-200" %>
  </div>
</div>

<div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
    <thead class="bg-gray-50 dark:bg-gray-900">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Title</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Articles</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Created</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
      <% @newsletters.each do |newsletter| %>
        <tr>
          <td class="px-4 py-3">
            <%= link_to newsletter.title, admin_newsletter_path(newsletter),
                class: "text-sm text-blue-600 dark:text-blue-400 font-medium hover:underline" %>
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">/<%= newsletter.slug %></div>
          </td>
          <td class="px-4 py-3">
            <% if newsletter.published? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                Published
              </span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                Draft
              </span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
            <%= newsletter.newsletter_articles.count %>
          </td>
          <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
            <%= newsletter.created_at.strftime("%b %d, %Y") %>
          </td>
          <td class="px-4 py-3 text-sm text-right space-x-2">
            <%= link_to "View", admin_newsletter_path(newsletter),
                class: "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" %>
            <%= link_to "Edit", edit_admin_newsletter_path(newsletter),
                class: "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" %>
          </td>
        </tr>
      <% end %>

      <% if @newsletters.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
            No newsletters yet. <%= link_to "Create your first newsletter", new_admin_newsletter_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
