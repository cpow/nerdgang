<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @newsletter.title %></title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f4f4f5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="max-width: 600px; width: 100%;">
          <!-- Header -->
          <tr>
            <td style="text-align: center; padding-bottom: 30px;">
              <h1 style="margin: 0; font-size: 24px; font-weight: 700; color: #18181b;">Power Dev</h1>
              <p style="margin: 8px 0 0 0; font-size: 14px; color: #71717a;">Weekly Developer Newsletter</p>
            </td>
          </tr>

          <!-- Main Content -->
          <tr>
            <td style="background-color: #ffffff; border-radius: 8px; padding: 32px;">
              <!-- Title -->
              <h2 style="margin: 0 0 8px 0; font-size: 28px; font-weight: 700; color: #18181b; line-height: 1.3;">
                <%= @newsletter.title %>
              </h2>
              <p style="margin: 0 0 24px 0; font-size: 14px; color: #71717a;">
                <%= @newsletter.published_at.strftime("%B %d, %Y") %>
              </p>

              <!-- Blurb -->
              <% if @newsletter.blurb.present? %>
                <div style="margin-bottom: 32px; font-size: 16px; line-height: 1.6; color: #3f3f46;">
                  <%= @newsletter.blurb.to_plain_text %>
                </div>
              <% end %>

              <!-- Articles -->
              <% if @newsletter.newsletter_articles.any? %>
                <h3 style="margin: 0 0 20px 0; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a;">
                  This Week's Top Stories
                </h3>

                <% @newsletter.newsletter_articles.each_with_index do |newsletter_article, index| %>
                  <% article = newsletter_article.article %>
                  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom: 24px;">
                    <tr>
                      <td style="padding-bottom: 16px; <%= index < @newsletter.newsletter_articles.size - 1 ? 'border-bottom: 1px solid #e4e4e7;' : '' %>">
                        <!-- Source Badge -->
                        <span style="display: inline-block; padding: 2px 8px; font-size: 11px; font-weight: 500; border-radius: 4px; margin-bottom: 8px;
                          <% if article.reddit? %>
                            background-color: #fef2f2; color: #dc2626;
                          <% elsif article.hackernews? %>
                            background-color: #fff7ed; color: #ea580c;
                          <% elsif article.lobsters? %>
                            background-color: #fdf2f8; color: #db2777;
                          <% elsif article.devto? %>
                            background-color: #f0fdf4; color: #16a34a;
                          <% else %>
                            background-color: #eff6ff; color: #2563eb;
                          <% end %>
                        ">
                          <%= article.source_name %>
                        </span>

                        <!-- Title -->
                        <h4 style="margin: 0 0 8px 0;">
                          <a href="<%= article.url %>" style="font-size: 18px; font-weight: 600; color: #18181b; text-decoration: none; line-height: 1.4;">
                            <%= article.title %>
                          </a>
                        </h4>

                        <!-- Meta -->
                        <p style="margin: 0 0 8px 0; font-size: 13px; color: #71717a;">
                          <%= article.domain %> &bull;
                          <%= article.score %> points &bull;
                          <a href="<%= article.discussion_url %>" style="color: #71717a; text-decoration: none;">
                            <%= pluralize(article.comments_count, "comment") %>
                          </a>
                        </p>

                        <!-- Commentary -->
                        <% if newsletter_article.commentary.present? %>
                          <p style="margin: 8px 0 0 0; font-size: 14px; font-style: italic; color: #52525b; line-height: 1.5;">
                            <%= newsletter_article.commentary %>
                          </p>
                        <% end %>
                      </td>
                    </tr>
                  </table>
                <% end %>
              <% end %>

              <!-- CTA -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top: 32px;">
                <tr>
                  <td align="center" style="padding: 24px; background-color: #fafafa; border-radius: 8px;">
                    <p style="margin: 0 0 16px 0; font-size: 16px; color: #3f3f46;">
                      Read the full newsletter with all links and formatting
                    </p>
                    <a href="<%= newsletter_url(@newsletter.slug) %>" style="display: inline-block; padding: 12px 24px; background-color: #18181b; color: #ffffff; font-size: 14px; font-weight: 500; text-decoration: none; border-radius: 6px;">
                      View in Browser
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 32px 20px; text-align: center;">
              <p style="margin: 0 0 8px 0; font-size: 13px; color: #71717a;">
                You received this email because you subscribed to Power Dev.
              </p>
              <p style="margin: 0; font-size: 13px; color: #71717a;">
                <a href="<%= @unsubscribe_url %>" style="color: #71717a; text-decoration: underline;">Unsubscribe</a>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
