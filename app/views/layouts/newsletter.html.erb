<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "Power Dev Newsletter" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Power Dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= content_for(:description) || "Your weekly developer news digest. Curated tech news, insights, and analysis delivered to your inbox." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "newsletter", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="nl-body" data-controller="newsletter-theme">
    <!-- Header -->
    <header class="nl-header">
      <div class="nl-header-inner">
        <%= link_to "Power Dev", newsletters_path, class: "nl-logo" %>

        <nav class="nl-nav">
          <%= link_to "Archive", newsletters_path, class: "nl-nav-link" %>
          <%= link_to "Main Site", root_path, class: "nl-nav-link" %>
        </nav>

        <div class="nl-header-actions">
          <button type="button" class="nl-theme-toggle" data-action="click->newsletter-theme#toggle" aria-label="Toggle dark mode">
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
            </svg>
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
          </button>
          <a href="#subscribe" class="nl-btn-cta">Subscribe</a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="nl-footer">
      <div class="nl-footer-inner">
        <div>
          <span class="nl-footer-brand">Power Dev</span>
          <span class="nl-footer-tagline"> - Your weekly developer news digest</span>
        </div>

        <div class="nl-footer-links">
          <%= link_to "Archive", newsletters_path, class: "nl-footer-link" %>
          <%= link_to "Main Site", root_path, class: "nl-footer-link" %>
        </div>

        <div class="nl-footer-copyright">
          Built with ❤️ by Chris Power
        </div>
      </div>
    </footer>
  </body>
</html>
