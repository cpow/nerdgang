<% content_for(:title) { "Power Dev Newsletter - Your Weekly Developer News Digest" } %>
<% content_for(:description) { "Join developers who get curated tech news, insights, and analysis delivered weekly. Stay informed without the noise." } %>

<!-- Hero Section -->
<section class="nl-hero" id="subscribe">
  <div class="nl-hero-inner">
    <h1 class="nl-hero-title">Weekly curated tech news that doesn't suck</h1>
    <p class="nl-hero-subtitle">
      Curated tech news, insights, and analysis delivered to your inbox every week.
      Skip the noise. Stay informed. Join developers who value their time.
    </p>

    <div id="subscribe-form" data-controller="subscribe-form">
      <%= form_with url: subscribers_path, class: "nl-subscribe-form" do |f| %>
        <%= f.email_field :email, name: "subscriber[email]", class: "nl-email-input", placeholder: "Enter your email", required: true, aria: { label: "Email address" } %>
        <%= f.submit "Subscribe Free", class: "nl-btn-cta nl-btn-cta-lg" %>
      <% end %>
      <div id="subscribe-form-error"></div>
      <p class="nl-social-proof">
        <strong>100% free.</strong> No spam. Unsubscribe anytime.
      </p>
    </div>
  </div>
</section>

<!-- Newsletter Archive -->
<section class="nl-main">
  <h2 class="nl-section-label">Latest Issues</h2>

  <% if @newsletters.any? %>
    <div class="nl-cards-grid">
      <% @newsletters.each do |newsletter| %>
        <%= link_to newsletter_path(newsletter.slug), class: "nl-card-link" do %>
          <article class="nl-card <%= 'nl-card-with-image' if newsletter.cover_image.attached? %>">
            <% if newsletter.cover_image.attached? %>
              <div class="nl-card-image">
                <%= image_tag newsletter.cover_image, alt: newsletter.title %>
              </div>
            <% end %>
            <div class="nl-card-content">
              <div class="nl-card-date">
                <%= newsletter.published_at.strftime("%B %d, %Y") %>
              </div>
              <h3 class="nl-card-title"><%= newsletter.title %></h3>
              <div class="nl-card-meta">
                <%= pluralize(newsletter.articles.count, "article") %> curated this week
              </div>
              <% if newsletter.blurb.present? %>
                <p class="nl-card-excerpt">
                  <%= truncate(newsletter.blurb.to_plain_text, length: 180) %>
                </p>
              <% end %>
            </div>
          </article>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="nl-empty-state">
      <p>No newsletters published yet. Subscribe above to be notified when the first issue drops!</p>
    </div>
  <% end %>
</section>
